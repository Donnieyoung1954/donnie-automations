<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Recruiter Bypass Kit™ — Beat ATS Filters & Land Interviews in 2026</title>
<meta name="description" content="75–90% of resumes are filtered before a recruiter sees them. The Recruiter Bypass Kit gives you 5 AI prompts to beat the filter and land interviews.">
{{ content_for_header }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black:   #0D0D0D;
    --dark:    #111111;
    --body:    #1A1A1A;
    --red:     #CC2200;
    --red-hover: #AA1A00;
    --white:   #FFFFFF;
    --light:   #F5F5F5;
    --mid:     #888888;
    --border:  #DDDDDD;
    --font: 'Inter', 'Open Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    font-size: 17px;
    color: var(--body);
    background: var(--white);
    line-height: 1.7;
  }

  .btn {
    display: block;
    width: 100%;
    background: var(--red);
    color: var(--white);
    font-family: var(--font);
    font-size: 17px;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    border: none;
    border-radius: 10px;
    height: 56px;
    line-height: 56px;
    cursor: pointer;
    transition: background 0.15s ease;
    letter-spacing: 0.02em;
  }
  .btn:hover { background: var(--red-hover); }

  header { position: sticky; top: 0; z-index: 100; background: var(--white); border-bottom: 1px solid var(--border); height: 64px; }
  .header-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; height: 64px; display: flex; align-items: center; justify-content: space-between; }
  .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .logo-chevron { color: var(--red); font-size: 20px; font-weight: 900; letter-spacing: -2px; line-height: 1; }
  .logo-text { font-size: 14px; font-weight: 800; color: var(--body); letter-spacing: 0.04em; line-height: 1.2; }
  nav { display: flex; align-items: center; gap: 32px; }
  nav a { font-size: 14px; color: var(--mid); text-decoration: none; transition: color 0.15s; }
  nav a:hover { color: var(--body); }
  .header-cta { background: var(--red); color: var(--white); font-size: 13px; font-weight: 700; padding: 0 20px; height: 38px; line-height: 38px; border-radius: 8px; text-decoration: none; letter-spacing: 0.03em; transition: background 0.15s; }
  .header-cta:hover { background: var(--red-hover); }

  #hero { background: var(--black); padding: 80px 40px; }
  .hero-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 55% 45%; gap: 48px; align-items: center; }
  .hero-pre { font-size: 12px; font-weight: 700; color: var(--red); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 12px; }
  .hero-h1 { font-size: 58px; font-weight: 900; color: var(--white); line-height: 1.08; margin-bottom: 20px; }
  .hero-sub { font-size: 18px; color: #AAAAAA; line-height: 1.6; max-width: 480px; margin-bottom: 24px; font-weight: 400; }
  .hero-bullets { list-style: none; margin-bottom: 32px; }
  .hero-bullets li { display: flex; align-items: flex-start; gap: 10px; color: var(--white); font-size: 16px; line-height: 1.5; margin-bottom: 12px; }
  .hero-bullets li::before { content: '›'; color: var(--red); font-size: 22px; font-weight: 900; line-height: 1.2; flex-shrink: 0; }
  .hero-btn-wrap { margin-bottom: 12px; }
  .secure-line { font-size: 13px; color: var(--mid); display: flex; align-items: center; gap: 6px; }
  .hero-right { display: flex; justify-content: center; align-items: center; }
  .book-mockup { position: relative; max-width: 360px; width: 100%; }
  .book-mockup img { width: 100%; border-radius: 8px; box-shadow: -16px 16px 48px rgba(0,0,0,0.6), 0 4px 24px rgba(0,0,0,0.4); transform: perspective(900px) rotateY(-8deg); display: block; }

  #trust { background: var(--white); border-top: 1px solid #EEEEEE; border-bottom: 1px solid #EEEEEE; padding: 28px 40px; }
  .trust-inner { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; text-align: center; }
  .trust-item { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .trust-icon { width: 36px; height: 36px; color: #555; }
  .trust-label { font-size: 14px; font-weight: 700; color: var(--body); }
  .trust-sub { font-size: 12px; color: var(--mid); }

  #problem { background: var(--white); padding: 80px 40px; }
  .problem-inner { max-width: 780px; margin: 0 auto; }
  .section-h2 { font-size: 40px; font-weight: 800; color: var(--body); line-height: 1.15; margin-bottom: 32px; text-align: center; }
  .body-p { font-size: 17px; color: var(--body); line-height: 1.75; margin-bottom: 24px; }
  .stat-box { border-left: 4px solid var(--red); background: var(--white); padding: 20px 24px; max-width: 600px; margin: 32px auto; font-size: 18px; font-weight: 700; color: var(--body); line-height: 1.5; }

  #bridge { background: var(--light); padding: 60px 40px; }
  .bridge-inner { max-width: 680px; margin: 0 auto; text-align: center; }
  .bridge-h2 { font-size: 36px; font-weight: 800; color: var(--body); margin-bottom: 16px; line-height: 1.2; }
  .bridge-body { font-size: 17px; color: var(--mid); line-height: 1.7; }

  #inside { background: var(--white); padding: 80px 40px; }
  .inside-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
  .section-pre { font-size: 12px; font-weight: 700; color: var(--red); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 6px; }
  .inside-h2 { font-size: 42px; font-weight: 800; color: var(--body); margin-bottom: 40px; line-height: 1.1; }
  .cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 24px; }
  .cards-grid-bottom { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; max-width: 720px; margin: 0 auto 40px; }
  .card { border: 1px solid #EEEEEE; border-radius: 12px; padding: 28px; text-align: left; transition: box-shadow 0.2s ease; }
  .card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); }
  .card-icon { width: 32px; height: 32px; color: var(--red); margin-bottom: 12px; }
  .card-prompt-num { font-size: 11px; font-weight: 700; color: var(--red); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; }
  .card-title { font-size: 18px; font-weight: 700; color: var(--body); margin-bottom: 10px; line-height: 1.3; }
  .card-body { font-size: 15px; color: var(--mid); line-height: 1.65; }
  .bonus-row { display: flex; align-items: flex-start; gap: 14px; background: var(--light); border-radius: 10px; padding: 20px 28px; max-width: 680px; margin: 0 auto; text-align: left; }
  .bonus-icon { width: 36px; height: 36px; color: var(--red); flex-shrink: 0; margin-top: 2px; }
  .bonus-title { font-size: 16px; font-weight: 700; color: var(--body); margin-bottom: 4px; }
  .bonus-sub { font-size: 14px; color: var(--mid); line-height: 1.6; }

  #who { background: var(--light); padding: 80px 40px; }
  .who-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .who-h2 { font-size: 30px; font-weight: 800; color: var(--body); margin-bottom: 24px; line-height: 1.2; }
  .checklist { list-style: none; }
  .checklist li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: var(--body); margin-bottom: 14px; line-height: 1.5; }
  .checklist li::before { content: '✓'; color: var(--red); font-weight: 900; font-size: 16px; flex-shrink: 0; margin-top: 1px; }
  .who-right { border-left: 1px solid var(--border); padding-left: 40px; }
  .who-note-label { font-size: 13px; color: var(--mid); font-style: italic; margin-bottom: 10px; }
  .who-note-body { font-size: 15px; color: #555555; line-height: 1.7; }

  #guarantee { background: var(--dark); padding: 80px 40px; }
  .guarantee-inner { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 180px 1fr; gap: 48px; align-items: center; }
  .badge { width: 160px; height: 160px; border-radius: 50%; border: 4px solid var(--red); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 16px; flex-shrink: 0; }
  .badge-num { font-size: 48px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 9px; font-weight: 700; color: var(--white); letter-spacing: 0.1em; text-transform: uppercase; line-height: 1.4; }
  .guarantee-h2 { font-size: 34px; font-weight: 800; color: var(--white); margin-bottom: 16px; line-height: 1.2; }
  .guarantee-body { font-size: 17px; color: #CCCCCC; line-height: 1.7; margin-bottom: 16px; }
  .guarantee-contact { font-size: 14px; color: var(--mid); }
  .guarantee-contact a { color: var(--mid); }

  #pricing { background: var(--white); padding: 80px 40px; text-align: center; }
  .pricing-inner { max-width: 480px; margin: 0 auto; }
  .pricing-label { font-size: 13px; color: var(--mid); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; }
  .pricing-price { font-size: 72px; font-weight: 900; color: var(--body); line-height: 1; margin-bottom: 6px; }
  .pricing-access { font-size: 13px; font-weight: 700; color: var(--red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 20px; }
  .payment-icons { display: flex; justify-content: center; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
  .pay-badge { font-size: 11px; font-weight: 600; color: var(--mid); border: 1px solid var(--border); border-radius: 4px; padding: 4px 10px; letter-spacing: 0.04em; }

  #faq { background: var(--light); padding: 80px 40px; }
  .faq-inner { max-width: 720px; margin: 0 auto; }
  .faq-h2 { font-size: 32px; font-weight: 800; color: var(--body); text-align: center; margin-bottom: 48px; line-height: 1.2; }
  .faq-item { padding-bottom: 28px; margin-bottom: 28px; border-bottom: 1px solid var(--border); }
  .faq-item:last-child { border-bottom: none; margin-bottom: 0; }
  .faq-q { font-size: 17px; font-weight: 700; color: var(--body); margin-bottom: 10px; line-height: 1.4; }
  .faq-a { font-size: 16px; color: #555555; line-height: 1.7; }

  #bottom-cta { background: var(--black); padding: 80px 40px; text-align: center; }
  .bottom-cta-inner { max-width: 600px; margin: 0 auto; }
  .bottom-cta-h2 { font-size: 38px; font-weight: 900; color: var(--white); margin-bottom: 12px; line-height: 1.15; }
  .bottom-cta-sub { font-size: 17px; color: var(--mid); margin-bottom: 28px; line-height: 1.5; }
  .bottom-cta-btn { max-width: 420px; margin: 0 auto 12px; }

  footer { background: var(--black); border-top: 1px solid #1E1E1E; padding: 48px 40px; }
  .footer-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 24px; }
  .footer-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
  .footer-logo .logo-chevron { color: var(--red); }
  .footer-logo .logo-text { color: var(--white); font-size: 13px; }
  .footer-right { text-align: right; }
  .footer-links { display: flex; gap: 20px; margin-bottom: 10px; justify-content: flex-end; }
  .footer-links a { font-size: 13px; color: var(--mid); text-decoration: none; transition: color 0.15s; }
  .footer-links a:hover { color: #AAAAAA; }
  .footer-copy { font-size: 12px; color: #444444; line-height: 1.6; }

  @media (max-width: 768px) {
    #hero, #trust, #problem, #bridge, #inside, #who, #guarantee, #pricing, #faq, #bottom-cta, footer { padding-left: 20px; padding-right: 20px; }
    .header-inner { padding: 0 20px; }
    nav { display: none; }
    .hero-inner { grid-template-columns: 1fr; }
    .hero-h1 { font-size: 36px; }
    .hero-sub { font-size: 16px; }
    .hero-right { order: -1; margin-bottom: 8px; }
    .book-mockup { max-width: 220px; }
    .book-mockup img { transform: none; }
    .trust-inner { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .section-h2 { font-size: 28px; }
    .bridge-h2 { font-size: 26px; }
    .inside-h2 { font-size: 30px; }
    .cards-grid { grid-template-columns: 1fr; }
    .cards-grid-bottom { grid-template-columns: 1fr; max-width: 100%; }
    .who-inner { grid-template-columns: 1fr; gap: 32px; }
    .who-right { border-left: none; padding-left: 0; border-top: 1px solid var(--border); padding-top: 24px; }
    .guarantee-inner { grid-template-columns: 1fr; justify-items: center; text-align: center; }
    .badge { width: 130px; height: 130px; }
    .badge-num { font-size: 38px; }
    .guarantee-h2 { font-size: 26px; }
    .pricing-price { font-size: 56px; }
    .bottom-cta-h2 { font-size: 28px; }
    .footer-inner { flex-direction: column; text-align: center; }
    .footer-right { text-align: center; }
    .footer-links { justify-content: center; }
  }

  /* EMAIL CAPTURE */
  #email-capture { background: #111111; padding: 70px 40px; }
  .capture-inner { max-width: 640px; margin: 0 auto; text-align: center; }
  .capture-h2 { font-size: 32px; font-weight: 800; color: var(--white); margin-bottom: 12px; line-height: 1.2; }
  .capture-sub { font-size: 16px; color: #999999; line-height: 1.6; margin-bottom: 28px; }
  .capture-form { display: flex; gap: 12px; max-width: 500px; margin: 0 auto; }
  .capture-form input[type="email"] { flex: 1; padding: 0 16px; height: 56px; border: 1px solid #333333; background: #1A1A1A; color: var(--white); font-size: 16px; border-radius: 8px; outline: none; transition: border-color 0.15s; }
  .capture-form input[type="email"]:focus { border-color: var(--red); }
  .capture-form input[type="email"]::placeholder { color: #666; }
  .capture-btn { width: auto; padding: 0 28px; white-space: nowrap; flex-shrink: 0; }
  .kl-success { color: #4CAF50; font-size: 15px; margin-top: 14px; font-weight: 600; }
  .kl-error { color: var(--red); font-size: 15px; margin-top: 14px; }
  @media (max-width: 600px) { #email-capture { padding-left: 20px; padding-right: 20px; } .capture-form { flex-direction: column; } .capture-btn { width: 100%; padding: 0; } }
</style>
</head>
<body>
{{ content_for_layout }}
</body>
</html>